# ===========================================
# Variables de Entorno - SQL Server Connection
# Fase 1: Infraestructura
# ===========================================

# Configuración del Servidor SQL Server
# Para instancia local: localhost\SQLEXPRESS o .\SQLEXPRESS
# Para instancia remota: 192.168.1.100 o servidor.dominio.com
DB_SERVER=localhost\SQLEXPRESS

# Nombre de la base de datos
DB_NAME=GestionDB

# Usuario de base de datos (SQL Auth)
# Nota: Se recomienda crear un usuario específico para la aplicación
DB_UID=gestion_user

# Password del usuario (mínimo 8 caracteres, mayúsculas, minúsculas, números y símbolos)
DB_PWD=ChangeMe_123!

# Opcional: Puerto (default 1433)
# DB_PORT=1433

# Opcional: Driver ODBC específico (normalmente se detecta automáticamente)
# DB_DRIVER=ODBC Driver 17 for SQL Server

# ===========================================
# Instrucciones:
# 1. Copiar este archivo como .env
# 2. Modificar los valores según la configuración local
# 3. Asegurar que el archivo .env NO se suba a Git (ya está en .gitignore)
# 4. Verificar instalación del driver ODBC
# ===========================================
